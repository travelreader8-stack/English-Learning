# Vercel Project Environment Variables
# Copy this file to .env.local for local dev (vercel dev),
# and configure these in Vercel Dashboard for production.

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

RESEND_API_KEY=
PARENT_EMAIL=jfmusa2024@gmail.com
# 可选：同时把成绩单抄送给学生本人。留空就只发家长。
STUDENT_EMAIL=
FROM_EMAIL=onboarding@resend.dev

STUDENT_TOKEN=

# Local-only — Azure TTS used by pipeline/hybrid_tts_render.py
# DO NOT add these to Vercel; podcasts are pre-rendered.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# Local-only — Tencent TTS used by pipeline/hybrid_tts_render.py for Chinese.
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_REGION=ap-beijing
