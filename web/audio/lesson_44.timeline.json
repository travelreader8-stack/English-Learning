        }
      ]
    },
    {
      "i": 53,
      "start": 422.45,
      "end": 431.162,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "risk"
      },
      "segments": [
        {
          "lang": "en",
          "text": "Risk"
        },
        {
          "lang": "zh",
          "text": "means danger, or the possibility that something bad may happen，风险，危险的可能。"
        }
      ]
    },
    {
      "i": 54,
      "start": 431.511,
      "end": 436.435,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "risk"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "课文说："
        },
        {
          "lang": "en",
          "text": "Mrs. Anne Sterling did not think of the risk she was taking."
        }
      ]
    },
    {
      "i": 55,
      "start": 436.785,
      "end": 444.241,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "risk"
      },
      "segments": [
        {
          "lang": "en",
          "text": "Take a risk"
        },
        {
          "lang": "zh",
          "text": "是冒险。她追两个男人穿过森林，这件事本身有 danger。"
        }
      ]
    },
    {
      "i": 56,
      "start": 444.591,
      "end": 452.711,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "risk"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "所以这个词也帮我们放住 safety boundary：we can admire the story, but we should not copy the risky chase."
        }
      ]
    },
    {
      "i": 57,
      "start": 453.061,
      "end": 455.813,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
