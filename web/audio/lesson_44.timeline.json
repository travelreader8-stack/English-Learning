        },
        {
          "lang": "zh",
          "text": "。"
        }
      ]
    },
    {
      "i": 58,
      "start": 456.163,
      "end": 457.867,
      "speaker": "B",
      "scene": "vocab",
      "scene_meta": {
        "word": "possession"
      },
      "segments": [
        {
          "lang": "en",
          "text": "possession"
        },
        {
          "lang": "zh",
          "text": "。"
        }
      ]
    },
    {
      "i": 59,
      "start": 458.216,
      "end": 467.208,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "possession"
      },
      "segments": [
        {
          "lang": "en",
          "text": "Possession"
        },
        {
          "lang": "zh",
          "text": "means having or holding something, or having it under your control，占有，拿在手里，控制着。"
        }
      ]
    },
    {
      "i": 60,
      "start": 467.558,
      "end": 470.85,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "possession"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "课文说："
        },
        {
          "lang": "en",
          "text": "with the bag in their possession"
        },
        {
          "lang": "zh",
          "text": "。"
        }
      ]
    },
    {
      "i": 61,
      "start": 471.2,
      "end": 480.12,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "possession"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "这不是说包真的属于他们，而是说 at that moment they had the bag。包从 Mrs. Sterling 手里，到了 the two men's hands。"
        }
      ]
    },
    {
      "i": 62,
      "start": 480.47,
      "end": 484.43,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "possession"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "物品位置一变，故事就从 struggle 进入 chase。"
        }
      ]
    },
    {
      "i": 63,
      "start": 484.78,
      "end": 487.772,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "contents"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "第三个词："
        },
        {
          "lang": "en",
          "text": "contents"
        },
        {
          "lang": "zh",
          "text": "。"
        }
      ]
    },
    {
      "i": 64,
      "start": 488.122,
      "end": 489.85,
      "speaker": "B",
      "scene": "vocab",
      "scene_meta": {
        "word": "contents"
      },
      "segments": [
        {
          "lang": "en",
          "text": "contents"
        },
        {
          "lang": "zh",
          "text": "。"
        }
      ]
    },
    {
      "i": 65,
      "start": 490.2,
      "end": 499.431,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "contents"
      },
      "segments": [
        {
          "lang": "en",
          "text": "Contents"
        },
        {
          "lang": "zh",
          "text": "means the things inside a container, a bag, a box, a book, or a message，里面的东西，内容物。"
        }
      ]
    },
    {
      "i": 66,
      "start": 499.781,
      "end": 503.721,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "contents"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "课文说："
        },
        {
          "lang": "en",
          "text": "They were going through the contents of the bag."
        }
      ]
    },
    {
      "i": 67,
      "start": 504.071,
      "end": 510.843,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "contents"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "这里"
        },
        {
          "lang": "en",
          "text": "go through"
        },
        {
          "lang": "zh",
          "text": "means search or look through，翻看、搜查。"
        }
      ]
    },
    {
      "i": 68,
      "start": 511.193,
      "end": 525.472,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "contents"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "同一个"
        },
        {
          "lang": "en",
          "text": "through"
        },
        {
          "lang": "zh",
          "text": "在今天有两个意思："
        },
        {
          "lang": "en",
          "text": "run through the trees"
        },
        {
          "lang": "zh",
          "text": "是穿过树林；"
        },
        {
          "lang": "en",
          "text": "go through the contents"
        },
        {
          "lang": "zh",
          "text": "是翻看包里的东西。Context decides the meaning."
        }
      ]
    },
    {
      "i": 69,
      "start": 525.822,
      "end": 529.742,
      "speaker": "A",
      "scene": "grammar",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "今天的 grammar board 分四块，全部贴着 action chain。"
        }
      ]
    },
    {
      "i": 70,
      "start": 530.092,
      "end": 553.923,
      "speaker": "A",
      "scene": "grammar",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "第一块，是 action verbs。课文把故事拍成镜头："
        },
        {
          "lang": "en",
          "text": "rushed up to her"
        },
        {
          "lang": "zh",
          "text": "，"
        },
        {
          "lang": "en",
          "text": "tried to steal her handbag"
        },
        {
          "lang": "zh",
          "text": "，"
        },
        {
          "lang": "en",
          "text": "the strap broke"
        },
        {
          "lang": "zh",
          "text": "，"
        },
        {
          "lang": "en",
          "text": "started running through the trees"
        },
        {
          "lang": "zh",
          "text": "，"
        },
        {
          "lang": "en",
          "text": "ran after them"
        },
        {
          "lang": "zh",
          "text": "，"
        },
        {
          "lang": "en",
          "text": "caught up with them"
        },
        {
          "lang": "zh",
          "text": "，"
        },
        {
          "lang": "en",
          "text": "ran straight at them"
        },
        {
          "lang": "zh",
          "text": "，"
        },
        {
          "lang": "en",
          "text": "dropped the bag and ran away"
        },
        {
          "lang": "zh",
          "text": "。"
        }
      ]
    },
    {
      "i": 71,
      "start": 554.273,
      "end": 561.653,
      "speaker": "A",
      "scene": "grammar",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "这就是 Action Chain Writing，动作链写作法。不要只说 result，要 show actions。"
        }
      ]
    },
    {
      "i": 72,
      "start": 562.003,
      "end": 576.995,
      "speaker": "A",
      "scene": "grammar",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "比如 summary 是："
        },
        {
          "lang": "en",
          "text": "She got her handbag back."
        },
        {
          "lang": "zh",
          "text": "Scene writing 是："
        },
        {
          "lang": "en",
          "text": "The strap broke. The men ran through the trees. Mrs. Sterling ran after them. She caught up with them."
        }
      ]
    },
    {
      "i": 73,
      "start": 577.345,
      "end": 585.617,
      "speaker": "A",
      "scene": "grammar",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "第二块，是"
        },
        {
          "lang": "en",
          "text": "so...that"
        },
        {
          "lang": "zh",
          "text": "。"
        },
        {
          "lang": "en",
          "text": "Mrs. Sterling got so angry that she ran after them."
        }
      ]
    },
    {
      "i": 74,
      "start": 585.966,
      "end": 593.558,
      "speaker": "A",
      "scene": "grammar",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "Pattern 是"
        },
        {
          "lang": "en",
          "text": "so + adjective + that + result"
        },
        {
          "lang": "zh",
          "text": "。Feeling 很强，所以后面发生了 action。"
        }
      ]
    },
    {
      "i": 75,
      "start": 593.908,
      "end": 601.836,
      "speaker": "A",
      "scene": "grammar",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "第三块，是"
        },
        {
          "lang": "en",
          "text": "such...that"
        },
        {
          "lang": "zh",
          "text": "。"
        },
        {
          "lang": "en",
          "text": "The men got such a fright that they dropped the bag and ran away."
        }
      ]
    },
    {
      "i": 76,
      "start": 602.186,
      "end": 613.438,
      "speaker": "A",
      "scene": "grammar",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "Pattern 是"
        },
        {
          "lang": "en",
          "text": "such + noun phrase + that + result"
        },
        {
          "lang": "zh",
          "text": "。"
        },
        {
          "lang": "en",
          "text": "A fright"
        },
        {
          "lang": "zh",
          "text": "是一个名词短语，所以用"
        },
        {
          "lang": "en",
          "text": "such a fright"
        },
        {
          "lang": "zh",
          "text": "。"
        }
      ]
    },
    {
      "i": 77,
      "start": 613.787,
      "end": 619.655,
      "speaker": "A",
      "scene": "grammar",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "第四块，是"
        },
        {
          "lang": "en",
          "text": "go through"
        },
        {
          "lang": "zh",
          "text": "和"
        },
        {
          "lang": "en",
          "text": "needs mending"
        },
        {
          "lang": "zh",
          "text": "。"
        }
      ]
    },
    {
      "i": 78,
      "start": 620.005,
      "end": 629.797,
      "speaker": "A",
      "scene": "grammar",
      "scene_meta": {},
      "segments": [
        {
          "lang": "en",
          "text": "Go through the forest"
        },
        {
          "lang": "zh",
          "text": "是 pass through the forest；"
        },
        {
          "lang": "en",
          "text": "go through the contents of the bag"
        },
        {
          "lang": "zh",
          "text": "是 search the things inside the bag。"
        }
      ]
    },
    {
      "i": 79,
      "start": 630.147,
      "end": 642.594,
      "speaker": "A",
      "scene": "grammar",
      "scene_meta": {},
      "segments": [
        {
          "lang": "en",
          "text": "The strap needs mending"
        },
        {
          "lang": "zh",
          "text": "意思是包带需要修。"
        },
        {
          "lang": "en",
          "text": "Mending"
        },
        {
          "lang": "zh",
          "text": "is repairing。今天更日常可以说："
        },
        {
          "lang": "en",
          "text": "The strap needs fixing."
        }
      ]
    },
    {
      "i": 80,
      "start": 642.944,
      "end": 648.664,
      "speaker": "A",
      "scene": "grammar",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "记住今天的原则：write the action chain clearly, but make the real-life choice safely."
        }
      ]
    },
    {
      "i": 81,
      "start": 649.014,
      "end": 655.574,
      "speaker": "A",
      "scene": "you_too",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "现在把这课放进你的生活。想象你在 park 里，看见有人 grab a bag and run away。"
        }
      ]
    },
    {
      "i": 82,
      "start": 655.924,
      "end": 663.036,
      "speaker": "A",
      "scene": "you_too",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "你可以用动作链描述发生了什么："
        },
        {
          "lang": "en",
          "text": "Two people rushed up to a woman and tried to steal her bag."
        }
      ]
    },
    {
      "i": 83,
      "start": 663.386,
      "end": 669.218,
      "speaker": "A",
      "scene": "you_too",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "接着说物品变化："
        },
        {
          "lang": "en",
          "text": "The strap broke, and they ran through the trees."
        }
      ]
    },
    {
      "i": 84,
      "start": 669.568,
      "end": 674.583,
      "speaker": "A",
      "scene": "you_too",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "然后加入真实安全选择："
        },
        {
          "lang": "en",
          "text": "I did not run after them."
        }
      ]
    },
    {
      "i": 85,
      "start": 674.933,
      "end": 682.973,
      "speaker": "A",
      "scene": "you_too",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "你可以用"
        },
        {
          "lang": "en",
          "text": "so...that"
        },
        {
          "lang": "zh",
          "text": "表达反应："
        },
        {
          "lang": "en",
          "text": "I was so surprised that I shouted for help."
        }
      ]
    },
    {
      "i": 86,
      "start": 683.323,
      "end": 688.147,
      "speaker": "A",
      "scene": "you_too",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "也可以报告结果："
        },
        {
          "lang": "en",
          "text": "I told a security guard which way they ran."
        }
      ]
    },
    {
      "i": 87,
      "start": 688.497,
      "end": 696.633,
      "speaker": "A",
      "scene": "you_too",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "最重要的一句是："
        },
        {
          "lang": "en",
          "text": "In real life, I should not chase thieves. I should keep myself safe and ask for help."
        }
      ]
    },
    {
      "i": 88,
      "start": 696.983,
      "end": 705.103,
      "speaker": "A",
      "scene": "you_too",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "这样你既能把 sudden event 讲成清楚的 action scene，又不会把课文里的 risky chase 当成现实建议。"
        }
      ]
    },
    {
      "i": 89,
      "start": 705.452,
      "end": 712.772,
      "speaker": "A",
      "scene": "outro",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "这一课就到这。下面先做 ⓪ 跟读：听课文全文 -> 听原音 -> 录一句 -> 获取反馈。"
        }
      ]
    },
    {
