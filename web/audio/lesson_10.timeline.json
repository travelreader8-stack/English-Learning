        }
      ]
    },
    {
      "i": 26,
      "start": 277.877,
      "end": 281.909,
      "speaker": "B",
      "scene": "passage_normal",
      "scene_meta": {},
      "segments": [
        {
          "lang": "en",
          "text": "She struck the keys too hard and two of the strings were broken."
        }
      ]
    },
    {
      "i": 27,
      "start": 282.259,
      "end": 284.491,
      "speaker": "B",
      "scene": "passage_normal",
      "scene_meta": {},
      "segments": [
        {
          "lang": "en",
          "text": "My father was shocked."
        }
      ]
    },
    {
      "i": 28,
      "start": 284.84,
      "end": 287.624,
      "speaker": "B",
      "scene": "passage_normal",
      "scene_meta": {},
      "segments": [
        {
          "lang": "en",
          "text": "Now we are not allowed to touch it."
        }
      ]
    },
    {
      "i": 29,
      "start": 287.974,
      "end": 291.31,
      "speaker": "B",
      "scene": "passage_normal",
      "scene_meta": {},
      "segments": [
        {
          "lang": "en",
          "text": "It is being repaired by a friend of my father's."
        }
      ]
    },
    {
      "i": 30,
      "start": 291.66,
      "end": 294.468,
      "speaker": "A",
      "scene": "vocab",
