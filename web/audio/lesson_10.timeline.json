        }
      ]
    },
    {
      "i": 31,
      "start": 294.818,
      "end": 296.618,
      "speaker": "B",
      "scene": "vocab",
      "scene_meta": {
        "word": "instrument"
      },
      "segments": [
        {
          "lang": "en",
