      "speaker": "B",
      "scene": "passage_normal",
      "scene_meta": {},
      "segments": [
        {
          "lang": "en",
          "text": "\"Certainly,\" the girl said."
        }
      ]
    },
    {
      "i": 38,
      "start": 392.306,
      "end": 395.45,
      "speaker": "B",
      "scene": "passage_normal",
      "scene_meta": {},
      "segments": [
        {
          "lang": "en",
          "text": "I went back to the ticket office at once."
        }
      ]
    },
    {
      "i": 39,
      "start": 395.8,
      "end": 400.168,
      "speaker": "B",
      "scene": "passage_normal",
      "scene_meta": {},
      "segments": [
        {
          "lang": "en",
          "text": "\"Could I have those two tickets please?\" I asked."
        }
      ]
    },
    {
      "i": 40,
      "start": 400.518,
      "end": 407.166,
      "speaker": "B",
      "scene": "passage_normal",
      "scene_meta": {},
      "segments": [
        {
          "lang": "en",
          "text": "\"Certainly,\" the girl said, \"but they're for next Wednesday's performance. Do you still want them?\""
        }
      ]
    },
    {
      "i": 41,
      "start": 407.516,
      "end": 410.756,
      "speaker": "B",
      "scene": "passage_normal",
      "scene_meta": {},
      "segments": [
        {
          "lang": "en",
          "text": "\"I might as well have them,\" I said sadly."
        }
      ]
    },
    {
