      "segments": [
        {
          "lang": "en",
          "text": "ticket"
        },
        {
          "lang": "zh",
          "text": "是票，表示你可以进入某个地方或参加某个活动。以前可能是一张纸票，现在也可能是手机里的二维码票。"
        }
      ]
    },
    {
      "i": 45,
      "start": 427.339,
      "end": 443.815,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "ticket"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "电影票可以说"
        },
        {
          "lang": "en",
          "text": "a movie ticket"
        },
        {
          "lang": "zh",
          "text": "，火车票是"
        },
        {
          "lang": "en",
          "text": "a train ticket"
        },
        {
          "lang": "zh",
          "text": "，演出票是"
        },
        {
          "lang": "en",
          "text": "a theatre ticket"
        },
        {
          "lang": "zh",
          "text": "。课文里"
        },
        {
          "lang": "en",
          "text": "narrator"
        },
        {
          "lang": "zh",
          "text": "问："
        },
        {
          "lang": "en",
          "text": "May I have two tickets please?"
        }
      ]
    },
    {
      "i": 46,
      "start": 444.165,
