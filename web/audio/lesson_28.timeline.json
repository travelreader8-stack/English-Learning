        }
      ]
    },
    {
      "i": 35,
      "start": 334.577,
      "end": 346.873,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "myth"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "今天只抓一个 myth bridge："
        },
        {
          "lang": "en",
          "text": "Medusa"
        },
        {
          "lang": "zh",
          "text": "，美杜莎，是 Greek myth 里有名的 Gorgon。她能把人变成石头这个设定，是 Jasper 笑话的关键。"
        }
      ]
    },
