      "speaker": "A",
      "scene": "grammar",
      "scene_meta": {},
      "segments": [
        {
          "lang": "en",
          "text": "has not been able to"
        },
        {
          "lang": "zh",
          "text": "很重要。它不是“那天没做到”，而是 up to now, not even once。到现在为止，他一次也没能把车开进 garage。"
        }
      ]
    },
