      "end": 689.303,
      "speaker": "A",
      "scene": "you_too",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "这道练习不是背奥运会知识，而是练习同一种表达：big event, many visitors, preparation, deadlines, and people looking forward to it。"
        }
      ]
