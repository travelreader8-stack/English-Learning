      ]
    },
    {
      "i": 81,
      "start": 674.289,
      "end": 678.793,
      "speaker": "A",
      "scene": "you_too",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "最后给出情绪："
        },
        {
          "lang": "en",
          "text": "Everybody is looking forward to it."
        }
      ]
    },
    {
