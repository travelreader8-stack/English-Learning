    },
    {
      "i": 99,
      "start": 757.487,
      "end": 762.287,
      "speaker": "A",
      "scene": "you_too",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "最后加上今天的核心："
        },
        {
          "lang": "en",
          "text": "I want to have a clear conscience."
        }
