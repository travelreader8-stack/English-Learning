      "segments": [
        {
          "lang": "en",
          "text": "foreigner"
        },
        {
          "lang": "zh",
          "text": "是外国人，意思是 a person from another country。这个词在这里是中性的、尊重的。叙述者说"
        },
        {
          "lang": "en",
          "text": "I am a foreigner"
        },
        {
          "lang": "zh",
          "text": "，是在解释：我不是本地人，请你说慢一点。"
        }
      ]
    },
    {
