    },
    {
      "i": 44,
      "start": 395.166,
      "end": 403.473,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "mad"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "你也可以说："
        },
        {
          "lang": "en",
          "text": "This homework is driving me mad."
        },
        {
          "lang": "zh",
          "text": "或者"
        },
        {
          "lang": "en",
          "text": "The noise outside is driving me mad."
        }
      ]
    },
