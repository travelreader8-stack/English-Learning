      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "sum"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "课文里说："
        },
        {
          "lang": "en",
          "text": "I have been offered a large sum of money to go away."
        },
        {
          "lang": "zh",
          "text": "这里像是一笔让他搬走的补偿或提议。"
        }
      ]
    },
    {
      "i": 49,
      "start": 425.454,
      "end": 432.662,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "sum"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "注意，"
        },
        {
          "lang": "en",
          "text": "have been offered"
        },
        {
          "lang": "zh",
          "text": "是“已经有人给我提出了这个条件”，不等于我已经接受了。"
        }
      ]
    },
