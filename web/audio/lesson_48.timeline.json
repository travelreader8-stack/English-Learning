      "i": 113,
      "start": 701.469,
      "end": 708.149,
      "speaker": "A",
      "scene": "grammar",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "这课里，它让我们看到：牙医以为在聊天，病人心里已经响起警报。"
        }
