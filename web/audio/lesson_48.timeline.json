      "speaker": "A",
      "scene": "grammar",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "所以今天的核心是：用间接问题呈现外部闲聊，用"
        },
        {
          "lang": "en",
          "text": "Meanwhile"
        },
        {
          "lang": "zh",
          "text": "切到内部警报，最后用"
        },
        {
          "lang": "en",
          "text": "had pulled out"
        },
