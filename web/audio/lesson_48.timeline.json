      "start": 737.036,
      "end": 745.236,
      "speaker": "A",
      "scene": "you_too",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "现在把这课放进生活场景。你在牙医诊所、校医室，或者刚做完检查，暂时不能正常说话。"
        }
