    },
    {
      "i": 114,
      "start": 708.499,
      "end": 713.603,
      "speaker": "A",
      "scene": "grammar",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "最后一块是过去完成时："
        },
        {
          "lang": "en",
          "text": "he had pulled out the wrong tooth"
        },
        {
          "lang": "zh",
          "text": "。"
        }
      ]
    },
    {
      "i": 115,
      "start": 713.953,
      "end": 723.089,
      "speaker": "A",
      "scene": "grammar",
      "scene_meta": {},
      "segments": [
        {
          "lang": "en",
          "text": "Had pulled out"
        },
        {
          "lang": "zh",
          "text": "说明拔错这件事已经发生。病人不是在提醒“别拔错”，而是在说“你已经拔错了”。"
        }
      ]
    },
    {
