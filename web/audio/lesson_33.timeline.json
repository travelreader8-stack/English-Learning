      "start": 691.159,
      "end": 699.555,
      "speaker": "A",
      "scene": "you_too",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "再说安全判断："
        },
        {
          "lang": "en",
          "text": "We should not go near the water."
        },
        {
          "lang": "zh",
          "text": "或者"
        },
