      "segments": [
        {
          "lang": "en",
          "text": "operation"
        },
        {
          "lang": "zh",
          "text": "在这课里是 surgery，医生做的手术。"
        }
      ]
    },
    {
      "i": 53,
      "start": 461.938,
      "end": 468.182,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "operation"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "课文说："
        },
        {
          "lang": "en",
          "text": "whether his operation had been successful"
        },
        {
          "lang": "zh",
          "text": "，意思是手术是否成功。"
        }
      ]
    },
    {
      "i": 54,
      "start": 468.532,
      "end": 478.132,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "operation"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "这个词也可以表示 computer operation, business operation, or math operation，但在医院故事里，它就是 medical operation。"
        }
      ]
    },
    {
      "i": 55,
      "start": 478.482,
      "end": 481.402,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "exchange"
      },
      "segments": [
