        }
      ]
    },
    {
      "i": 56,
      "start": 481.752,
      "end": 483.576,
      "speaker": "B",
      "scene": "vocab",
      "scene_meta": {
        "word": "exchange"
      },
      "segments": [
        {
          "lang": "en",
          "text": "exchange"
        },
        {
          "lang": "zh",
          "text": "。"
        }
      ]
    },
    {
      "i": 57,
      "start": 483.926,
      "end": 490.685,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "exchange"
      },
      "segments": [
        {
          "lang": "en",
          "text": "exchange"
        },
        {
          "lang": "zh",
          "text": "在这课里是 telephone exchange，医院电话总机或 switchboard。"
        }
      ]
    },
    {
      "i": 58,
      "start": 491.035,
      "end": 501.127,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "exchange"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "课文说："
        },
        {
          "lang": "en",
          "text": "he telephoned the hospital exchange"
        },
        {
          "lang": "zh",
          "text": "。他不是去交换东西，也不是换钱，而是打给总机，请总机帮他接到 Doctor Millington。"
        }
      ]
    },
    {
      "i": 59,
      "start": 501.477,
      "end": 509.317,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "exchange"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "所以这课里的"
        },
        {
          "lang": "en",
          "text": "exchange"
        },
        {
          "lang": "zh",
          "text": "可以记成 old phone connection point，老式电话系统里的连接点。"
        }
      ]
    },
    {
      "i": 60,
      "start": 509.667,
      "end": 512.659,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "relative"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "第三个词："
        },
        {
          "lang": "en",
          "text": "relative"
        },
        {
          "lang": "zh",
          "text": "。"
        }
      ]
    },
    {
      "i": 61,
      "start": 513.009,
      "end": 514.785,
      "speaker": "B",
      "scene": "vocab",
      "scene_meta": {
        "word": "relative"
      },
      "segments": [
        {
          "lang": "en",
          "text": "relative"
        },
        {
          "lang": "zh",
          "text": "。"
        }
      ]
    },
    {
      "i": 62,
      "start": 515.134,
      "end": 524.726,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "relative"
      },
      "segments": [
        {
          "lang": "en",
          "text": "relative"
        },
        {
          "lang": "zh",
          "text": "是 family member，亲属，比如 parent, child, brother, sister, uncle, aunt。"
        }
      ]
    },
    {
      "i": 63,
      "start": 525.076,
      "end": 530.432,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "relative"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "课文说："
        },
        {
          "lang": "en",
          "text": "Dr. Millington asked the caller if he was a relative of the patient."
        }
      ]
    },
    {
      "i": 64,
      "start": 530.782,
      "end": 540.822,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "relative"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "医生想确认 caller 和 patient 的关系。这个词也连接到今天的 privacy rule：不是谁打电话来，都有权知道病人的 private information。"
        }
      ]
    },
    {
      "i": 65,
      "start": 541.172,
      "end": 548.572,
      "speaker": "A",
      "scene": "grammar",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "今天的 grammar 是 indirect questions and reported questions，但不要背成干表格。它正好解释这个 phone trick。"
        }
      ]
    },
    {
      "i": 66,
      "start": 548.922,
      "end": 558.602,
      "speaker": "A",
      "scene": "grammar",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "直接问题是："
        },
        {
          "lang": "en",
          "text": "Was my operation successful?"
        },
        {
          "lang": "zh",
          "text": "课文变成："
        },
        {
          "lang": "en",
          "text": "whether his operation had been successful"
        },
        {
          "lang": "zh",
          "text": "。"
        }
      ]
    },
    {
      "i": 67,
      "start": 558.951,
      "end": 569.951,
      "speaker": "A",
      "scene": "grammar",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "电话里的问题是："
        },
        {
          "lang": "en",
          "text": "Has Mr. Gilbert's operation been successful?"
        },
        {
          "lang": "zh",
          "text": "课文变成："
        },
        {
          "lang": "en",
          "text": "if Mr. Gilbert's operation had been successful"
        },
        {
          "lang": "zh",
          "text": "。"
        }
      ]
    },
    {
      "i": 68,
      "start": 570.301,
      "end": 581.525,
      "speaker": "A",
      "scene": "grammar",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "直接问“什么时候能回家”是："
        },
        {
          "lang": "en",
          "text": "When can Mr. Gilbert go home?"
        },
        {
          "lang": "zh",
          "text": "课文变成："
        },
        {
          "lang": "en",
          "text": "when Mr. Gilbert would be allowed to go home"
        },
        {
          "lang": "zh",
          "text": "。"
        }
      ]
    },
    {
      "i": 69,
      "start": 581.875,
      "end": 590.346,
      "speaker": "A",
      "scene": "grammar",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "医生的问题是："
        },
        {
          "lang": "en",
          "text": "Are you a relative?"
        },
        {
          "lang": "zh",
          "text": "课文变成："
        },
        {
          "lang": "en",
          "text": "if he was a relative of the patient"
        },
        {
          "lang": "zh",
          "text": "。"
        }
      ]
    },
    {
      "i": 70,
      "start": 590.696,
      "end": 601.544,
      "speaker": "A",
      "scene": "grammar",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "你会发现，indirect question 里不再用普通疑问句语序。不是"
        },
        {
          "lang": "en",
          "text": "when would he be allowed"
        },
        {
          "lang": "zh",
          "text": "，而是"
        },
        {
          "lang": "en",
          "text": "when he would be allowed"
        },
        {
          "lang": "zh",
          "text": "。"
        }
      ]
    },
    {
      "i": 71,
      "start": 601.894,
      "end": 611.534,
      "speaker": "A",
      "scene": "grammar",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "故事里也一样：John 不再直接站在病床边问 doctor。他绕了一圈，用 formal phone inquiry 问 about a certain patient。"
        }
      ]
    },
    {
      "i": 72,
      "start": 611.884,
      "end": 624.284,
      "speaker": "A",
      "scene": "grammar",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "所以语法板可以这样记：direct question refused；indirect phone question answered；caller equals patient。句子是 indirect，整个电话也是 indirect。"
        }
      ]
    },
    {
      "i": 73,
      "start": 624.634,
      "end": 634.074,
      "speaker": "A",
      "scene": "you_too",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "现在把这课放进你的生活。想象你打电话给 school office，询问自己的 activity result or appointment。"
        }
      ]
    },
    {
      "i": 74,
      "start": 634.424,
      "end": 642.984,
      "speaker": "A",
      "scene": "you_too",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "你要做的是 polite and privacy-aware inquiry，不是假装别人，也不询问别人的私人信息。"
        }
      ]
    },
    {
      "i": 75,
      "start": 643.333,
      "end": 648.389,
      "speaker": "A",
      "scene": "you_too",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "可以这样开头："
        },
        {
          "lang": "en",
          "text": "Hello, I am calling about my activity result."
        }
      ]
    },
    {
      "i": 76,
      "start": 648.739,
      "end": 652.259,
      "speaker": "A",
      "scene": "you_too",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "先说明身份："
        },
        {
          "lang": "en",
          "text": "My name is Li Ming."
        }
      ]
    },
    {
      "i": 77,
      "start": 652.609,
      "end": 658.169,
      "speaker": "A",
      "scene": "you_too",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "礼貌询问结果："
        },
        {
          "lang": "en",
          "text": "Could you tell me whether my application was successful?"
        }
      ]
    },
    {
      "i": 78,
      "start": 658.519,
      "end": 664.423,
      "speaker": "A",
      "scene": "you_too",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "再问时间安排："
        },
        {
          "lang": "en",
          "text": "Could you also tell me when I will be allowed to join the activity?"
        }
      ]
    },
    {
      "i": 79,
      "start": 664.773,
      "end": 670.456,
      "speaker": "A",
      "scene": "you_too",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "如果对方需要确认身份，可以说："
        },
        {
          "lang": "en",
          "text": "Do you need to check my identity?"
        }
      ]
    },
    {
      "i": 80,
      "start": 670.806,
      "end": 676.902,
      "speaker": "A",
      "scene": "you_too",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "最后补上一句隐私意识："
        },
        {
          "lang": "en",
          "text": "I understand that this information is private."
        }
      ]
    },
    {
      "i": 81,
      "start": 677.252,
      "end": 685.292,
      "speaker": "A",
      "scene": "you_too",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "这道练习的核心不是“聪明绕路”，而是用 if, whether, and when 把问题问得 polite, clear, and responsible。"
        }
      ]
    },
    {
      "i": 82,
      "start": 685.642,
      "end": 711.725,
      "speaker": "A",
      "scene": "outro",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "这一课就到这。下面先做 ⓪ 跟读：听课文全文 -> 听原音 -> 录一句 -> 获取反馈，把"
        },
        {
          "lang": "en",
          "text": "whether his operation had been successful"
        },
        {
          "lang": "zh",
          "text": "、"
        },
        {
          "lang": "en",
          "text": "hospital exchange"
        },
        {
          "lang": "zh",
          "text": "、"
        },
        {
          "lang": "en",
          "text": "inquiring about a certain patient"
        },
        {
          "lang": "zh",
          "text": "、"
        },
        {
          "lang": "en",
          "text": "would be allowed to go home"
        },
        {
          "lang": "zh",
          "text": "、"
        },
        {
          "lang": "en",
          "text": "another two weeks"
        },
        {
          "lang": "zh",
          "text": "和"
        },
        {
          "lang": "en",
          "text": "a relative of the patient"
        },
        {
          "lang": "zh",
          "text": "读顺。"
        }
      ]
    },
    {
      "i": 83,
      "start": 712.075,
      "end": 735.315,
      "speaker": "A",
      "scene": "outro",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "跟读完以后，再做 ① 生活场景，练习 polite and privacy-aware phone inquiry；后面 ② 完形 ③ 中译英 ④ 英译中 ⑤ 默写 一条线做下来。做完以后，爸爸的邮箱里就会收到你今天的成绩。记住今天的核心：John sounded like a caller asking about a patient, but the patient was John himself."
        }
      ]
    }
  ],
