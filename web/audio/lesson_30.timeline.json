      "end": 116.833,
      "speaker": "A",
      "scene": "retell",
      "scene_meta": {
        "frame": "1"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "上星期日很暖和，所以他"
        },
        {
          "lang": "en",
          "text": "went and sat on the river bank as usual"
        },
        {
          "lang": "zh",
          "text": "。注意"
