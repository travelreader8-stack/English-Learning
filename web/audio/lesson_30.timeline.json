      "end": 90.702,
      "speaker": "A",
      "scene": "retell",
      "scene_meta": {
        "frame": "1"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "故事先给我们地点："
        },
        {
          "lang": "en",
          "text": "The Wayle is a small river that cuts across the park near my home."
        },
        {
          "lang": "en",
          "text": "cuts across"
        },
        {
          "lang": "zh",
          "text": "是横穿、穿过，像一条小河从公园中间经过。"
        }
      ]
    },
    {
      "i": 7,
      "start": 91.052,
      "end": 102.028,
      "speaker": "A",
      "scene": "retell",
      "scene_meta": {
        "frame": "1"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "narrator 喜欢这里："
        },
        {
          "lang": "en",
          "text": "I like sitting by the Wayle on fine afternoons."
