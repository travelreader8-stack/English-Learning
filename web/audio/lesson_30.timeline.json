    {
      "i": 21,
      "start": 238.515,
      "end": 243.366,
      "speaker": "B",
      "scene": "discuss",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "因为足球飞到河上的小船那边，好像游戏跑到水上去了？"
        }
