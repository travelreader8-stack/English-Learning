      "start": 27.524,
      "end": 38.675,
      "speaker": "A",
      "scene": "hook",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "先把空间摆清楚。这里的"
        },
        {
          "lang": "en",
          "text": "bank"
        },
        {
          "lang": "zh",
          "text": "不是 money bank，不是银行，而是"
        },
        {
          "lang": "en",
          "text": "river bank"
        },
        {
          "lang": "zh",
          "text": "，河岸，也就是河边的土地。"
        }
      ]
    },
