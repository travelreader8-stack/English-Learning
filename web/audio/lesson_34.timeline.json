    },
    {
      "i": 61,
      "start": 473.13,
      "end": 484.274,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "most"
      },
      "segments": [
        {
          "lang": "en",
          "text": "most"
        },
        {
          "lang": "zh",
          "text": "常见意思是“最多、最”，但这课的"
