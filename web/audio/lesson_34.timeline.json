    },
    {
      "i": 60,
      "start": 471.244,
      "end": 472.78,
      "speaker": "B",
      "scene": "vocab",
      "scene_meta": {
        "word": "most"
      },
      "segments": [
        {
          "lang": "en",
          "text": "most"
        },
        {
          "lang": "zh",
          "text": "。"
