          "text": "更像 very surprised，非常惊讶。"
        }
      ]
    },
    {
      "i": 62,
      "start": 484.624,
      "end": 490.96,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "most"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "这种用法有一点 formal，old-fashioned，可以理解成"
        },
        {
          "lang": "en",
          "text": "Dan was very surprised"
        },
        {
          "lang": "zh",
          "text": "。"
        }
      ]
    },
    {
      "i": 63,
      "start": 491.31,
      "end": 501.01,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "most"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "课文说："
        },
        {
          "lang": "en",
          "text": "Dan was most surprised when he heard the news."
        },
        {
          "lang": "zh",
          "text": "他惊讶，是因为这辆自行车不是刚丢的，而是 twenty years ago 被偷的。"
        }
      ]
    },
    {
      "i": 64,
      "start": 501.359,
      "end": 504.231,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
