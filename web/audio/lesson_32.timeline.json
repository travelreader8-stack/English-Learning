        },
        {
          "lang": "en",
          "text": "fewer people than usual"
        },
        {
          "lang": "zh",
          "text": "、"
        },
        {
          "lang": "en",
          "text": "one of the most expensive dresses"
        },
        {
          "lang": "zh",
          "text": "、"
        },
        {
