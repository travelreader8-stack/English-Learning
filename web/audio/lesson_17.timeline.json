        {
          "lang": "en",
          "text": "appear"
        },
        {
          "lang": "zh",
          "text": "可以是出现，也可以是在别人面前呈现出某种样子。课文里是舞台用法："
        },
        {
          "lang": "en",
          "text": "She often appears on the stage as a young girl."
        },
        {
          "lang": "zh",
          "text": "她在舞台上呈现成年轻女孩的角色。"
        }
      ]
    },
    {
      "i": 38,
      "start": 375.477,
      "end": 388.925,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "appear"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "你也可以说："
        },
        {
          "lang": "en",
          "text": "A singer appears on screen."
        },
        {
          "lang": "zh",
          "text": "歌手出现在屏幕上。"
        },
        {
          "lang": "en",
          "text": "A student appears as a detective in a school play."
        },
        {
          "lang": "zh",
