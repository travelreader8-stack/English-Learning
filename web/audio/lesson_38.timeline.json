      "i": 88,
      "start": 667.236,
      "end": 675.532,
      "speaker": "A",
      "scene": "you_too",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "如果天气会影响生活，可以说："
        },
        {
          "lang": "en",
          "text": "If it rains continually or is bitterly cold, daily life may be different."
        }
      ]
    },
    {
      "i": 89,
      "start": 675.882,
      "end": 681.45,
      "speaker": "A",
      "scene": "you_too",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "最后用标题句型收住："
        },
        {
          "lang": "en",
          "text": "I should not think of everything except the weather."
        }
      ]
    },
