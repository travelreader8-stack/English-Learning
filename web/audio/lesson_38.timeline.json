      "end": 666.886,
      "speaker": "A",
      "scene": "you_too",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "你还要检查 daily factors："
        },
        {
          "lang": "en",
          "text": "I must think about the weather, transport, food, friends, and routine."
        }
      ]
    },
