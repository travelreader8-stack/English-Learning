      "start": 517.379,
      "end": 520.815,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "bitterly"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "课文说："
        },
        {
          "lang": "en",
          "text": "It was often bitterly cold."
        }
      ]
    },
    {
      "i": 70,
      "start": 521.164,
      "end": 531.568,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "bitterly"
      },
