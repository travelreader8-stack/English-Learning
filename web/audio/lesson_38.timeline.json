      "end": 597.978,
      "speaker": "A",
      "scene": "grammar",
      "scene_meta": {},
      "segments": [
        {
          "lang": "en",
          "text": "hardly... when..."
        },
        {
          "lang": "zh",
          "text": "表示几乎还没来得及安顿，就已经卖房离开。"
        }
