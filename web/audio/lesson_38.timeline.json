    {
      "i": 63,
      "start": 481.504,
      "end": 484.604,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "continually"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "课文说："
        },
        {
          "lang": "en",
          "text": "It rained continually."
