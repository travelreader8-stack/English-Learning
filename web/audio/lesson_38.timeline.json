      "start": 644.509,
      "end": 648.533,
      "speaker": "A",
      "scene": "you_too",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "可以这样开头："
        },
        {
          "lang": "en",
          "text": "I have dreamed of living near the sea."
