        {
          "lang": "en",
          "text": "I have planned the house and the school."
        }
      ]
    },
    {
      "i": 86,
      "start": 653.585,
      "end": 658.753,
      "speaker": "A",
      "scene": "you_too",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "然后提醒自己不要太快决定："
        },
        {
          "lang": "en",
          "text": "But I should not decide immediately."
        }
      ]
    },
    {
      "i": 87,
