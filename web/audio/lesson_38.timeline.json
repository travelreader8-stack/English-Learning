      "start": 681.8,
      "end": 687.28,
      "speaker": "A",
      "scene": "you_too",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "这道练习不是叫你不要做梦，而是让 dream picture 加上 real daily life。"
