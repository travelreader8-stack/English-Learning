      "start": 598.247,
      "end": 606.943,
      "speaker": "A",
      "scene": "you_too",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "下面练习里，用"
        },
        {
          "lang": "en",
          "text": "word bank"
        },
        {
          "lang": "zh",
          "text": "填三个空，说清楚“别人看什么结果、你真正享受什么过程”。"
        }
      ]
    },
    {
