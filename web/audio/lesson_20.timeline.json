      "end": 401.24,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "catch"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "课文说："
        },
        {
          "lang": "en",
          "text": "I often fish for hours without catching anything."
        },
