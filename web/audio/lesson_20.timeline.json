      "end": 553.378,
      "speaker": "A",
      "scene": "grammar",
      "scene_meta": {},
      "segments": [
        {
          "lang": "zh",
          "text": "还有两个小表达。"
        },
        {
          "lang": "en",
          "text": "not even"
        },
        {
          "lang": "zh",
          "text": "是“甚至连……都不”，所以"
        },
        {
          "lang": "en",
          "text": "not even old boots"
        },
        {
          "lang": "zh",
          "text": "很好笑。"
        },
        {
          "lang": "en",
          "text": "at all"
