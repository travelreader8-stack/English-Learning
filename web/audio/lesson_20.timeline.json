      "start": 441.734,
      "end": 451.658,
      "speaker": "A",
      "scene": "vocab",
      "scene_meta": {
        "word": "realize"
      },
      "segments": [
        {
          "lang": "zh",
          "text": "课文说："
        },
        {
          "lang": "en",
          "text": "They don't realize one important thing."
        },
        {
          "lang": "zh",
          "text": "朋友没有意识到真正的重点：他不是为了鱼，他是为了坐在船上安静一会儿。"
        }
      ]
